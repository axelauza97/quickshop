# PostgreSQL (used by docker-compose db service)
POSTGRES_USER=quickshop
POSTGRES_PASSWORD=quickshop
POSTGRES_DB=quickshop

# Auth0 (required — shared by backend and frontend)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://your-api-identifier/
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_CLIENT_ID=your-client-id
# Optional TLS overrides for corporate/self-signed cert chains:
# AUTH0_CA_CERT_PATH=/app/certs/corporate-root-ca.pem
# AUTH0_SKIP_TLS_VERIFY=false

# Backend
DATABASE_URL=postgresql+psycopg://quickshop:quickshop@db:5432/quickshop
ALLOWED_ORIGINS=http://localhost:3000
SEED_FIXTURES=false

# Frontend (NEXT_PUBLIC_ prefix makes vars available client-side)
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=https://your-api-identifier/
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000
